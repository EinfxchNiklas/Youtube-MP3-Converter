# Copy this to .env for local development
SECRET_KEY=dev-secret-please-change
APP_USERNAME=admin
APP_PASSWORD=changeme

# Optional: YouTube-Cookies gegen Bot-Erkennung (Netscape-Format, z.B. aus "Get cookies.txt LOCALLY")
# Lokal leer lassen; auf Render den gesamten Inhalt der cookies.txt eintragen.
# YOUTUBE_COOKIES=
